# /etc/dmf-mail/env
# Copy this file to the server and fill in the values before running setup.sh

# REQUIRED – replace with a long random string (e.g. openssl rand -hex 32)
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# Initial admin credentials (used only on first startup to seed the database)
INITIAL_ADMIN_EMAIL=admin@dutchforcesrp.nl
INITIAL_ADMIN_PASSWORD=ChangeMe123!

# Mail storage root (must match Dovecot mail_home base)
MAILBOX_ROOT=/var/mail/vhosts/dutchforcesrp.nl

# Outbound SMTP relay (required when ISP blocks port 25 – e.g. Brevo)
RELAY_HOST=[smtp-relay.brevo.com]:587
RELAY_LOGIN=your_brevo_login@smtp-brevo.com
RELAY_PASSWORD=your_brevo_smtp_password
