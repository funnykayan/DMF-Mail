# /etc/dovecot/auth-passwdfile.conf.ext – DMF Mail
# Passwd file is managed by DMF Mail backend (postfix_utils.py)
# Format: email:hashed_pw:uid:gid::home_dir::

passdb {
  driver   = passwd-file
  args     = scheme=SHA512-CRYPT username_format=%u /etc/dovecot/users
}

userdb {
  driver   = passwd-file
  args     = username_format=%u /etc/dovecot/users
  default_fields = uid=vmail gid=vmail home=/var/mail/vhosts/%d/%n
}
